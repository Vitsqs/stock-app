# ============================================================
# СКОПИРУЙ ЭТОТ ФАЙЛ В .env И ЗАПОЛНИ ЗНАЧЕНИЯ
# ============================================================

# 1. PostgreSQL — берёшь на Railway после создания базы
#    Railway → твой проект → PostgreSQL → Connect → DATABASE_URL
DATABASE_URL="postgresql://postgres:password@localhost:5432/stockapp"

# 2. Токен бота — берёшь у @BotFather в Telegram
#    /newbot → придумай имя → скопируй токен
TELEGRAM_BOT_TOKEN="123456789:AABBccDDeeFFggHH"

# 3. URL твоего приложения на Railway
#    Railway → твой сервис → Settings → Public Domain → Generate
#    Вставляй С https://
MINI_APP_URL="https://stock-app-xxx.up.railway.app"
NEXT_PUBLIC_MINI_APP_URL="https://stock-app-xxx.up.railway.app"

# 4. Секретный ключ для JWT — любые 32+ символов, можно рандомно набить
JWT_SECRET="verySecretKey-changeThis-min32chars!"
